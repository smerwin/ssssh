# ssssh.xcodeproj IS checked in (Xcode Cloud needs a real project file in
# the repo to discover a workflow) even though it's generated by
# `xcodegen generate` from project.yml. Only its user-specific cruft is
# ignored -- after editing project.yml, regenerate and commit the project.
ssssh.xcodeproj/xcuserdata/
